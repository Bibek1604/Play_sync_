import 'package:camera/camera.dart';
import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:play_sync_new/app/theme/dynamic_theme_service.dart';
import 'package:play_sync_new/core/constants/app_colors.dart';

/// Camera Screen with Dynamic Dark Mode Integration
/// 
/// Switches themes based on Light/Dark detection via Front (Selfie) Camera:
/// 1. Uses Front Camera (Selfie) to detect light levels.
/// 2. If camera is covered (e.g. by finger), it triggers DARK MODE.
/// 3. If uncovered (light detected), it triggers LIGHT MODE.
class CameraThemeExampleScreen extends ConsumerStatefulWidget {
  const CameraThemeExampleScreen({super.key});

  @override
  ConsumerState<CameraThemeExampleScreen> createState() => _CameraThemeExampleScreenState();
}

class _CameraThemeExampleScreenState extends ConsumerState<CameraThemeExampleScreen> with WidgetsBindingObserver {
  CameraController? _controller;
  List<CameraDescription>? _cameras;
  bool _isCameraInitialized = false;
  bool _isProcessingFrame = false;
  String? _error;
  double _lastLuminance = 0;

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
    _initCameras();
  }

  /// Initialize available cameras
  Future<void> _initCameras() async {
    try {
      _cameras = await availableCameras();
      if (_cameras != null && _cameras!.isNotEmpty) {
        // Find front camera (selfie)
        final frontCamera = _cameras!.firstWhere(
          (c) => c.lensDirection == CameraLensDirection.front,
          orElse: () => _cameras![0],
        );
        await _startCamera(frontCamera);
      } else {
        setState(() => _error = 'No cameras found on this device');
      }
    } catch (e) {
      if (mounted) {
        setState(() => _error = 'Camera Initialization Error: $e');
      }
    }
  }

  /// Start a specific camera and notify theme service
  Future<void> _startCamera(CameraDescription description) async {
    ref.read(cameraActiveProvider.notifier).state = true;

    final controller = CameraController(
      description,
      ResolutionPreset.low, // Lower resolution is faster for frame processing
      enableAudio: false,
      imageFormatGroup: ImageFormatGroup.yuv420,
    );

    _controller = controller;

    try {
      await controller.initialize();
      
      // Start Image Stream for Darkness detection
      await controller.startImageStream((image) {
        if (_isProcessingFrame) return;
        _processCameraImage(image);
      });

      if (mounted) {
        setState(() => _isCameraInitialized = true);
      }
    } catch (e) {
      if (mounted) {
        setState(() => _error = 'Failed to initialize camera: $e');
        ref.read(cameraActiveProvider.notifier).state = false;
      }
    }
  }

  /// Processes camera frames to detect average brightness
  void _processCameraImage(CameraImage image) {
    _isProcessingFrame = true;
    
    try {
      // YUV420 format: Plane 0 is the Y (Luminance) channel
      final bytes = image.planes[0].bytes;
      
      // Calculate average luminance
      double totalLuminance = 0;
      // Sample pixels for performance
      for (int i = 0; i < bytes.length; i += 10) {
        totalLuminance += bytes[i];
      }
      
      final averageLuminance = totalLuminance / (bytes.length / 10);
      
      if (mounted) {
        setState(() => _lastLuminance = averageLuminance);
        
        // Darkness threshold (finger over camera usually gives < 10)
        final isDark = averageLuminance < 30.0; 
        
        final currentDarknessState = ref.read(cameraDarknessDetectedProvider);
        if (isDark != currentDarknessState) {
          ref.read(cameraDarknessDetectedProvider.notifier).state = isDark;
        }
      }
    } catch (e) {
      debugPrint('Error processing frame: $e');
    } finally {
      _isProcessingFrame = false;
    }
  }

  /// Stop camera and notify theme service to revert mode
  Future<void> _stopCamera() async {
    if (_controller != null) {
      if (_controller!.value.isStreamingImages) {
        await _controller!.stopImageStream();
      }
      await _controller!.dispose();
      _controller = null;
    }
    if (mounted) {
      setState(() => _isCameraInitialized = false);
      ref.read(cameraActiveProvider.notifier).state = false;
      ref.read(cameraDarknessDetectedProvider.notifier).state = false;
    }
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState state) {
    if (_controller == null || !_controller!.value.isInitialized) return;

    if (state == AppLifecycleState.inactive) {
      _stopCamera();
    } else if (state == AppLifecycleState.resumed) {
      _initCameras();
    }
  }

  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    _controller?.dispose();
    ref.read(cameraActiveProvider.notifier).state = false;
    ref.read(cameraDarknessDetectedProvider.notifier).state = false;
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final theme = Theme.of(context);
    final isDarkNow = theme.brightness == Brightness.dark;
    final isDarknessDetected = ref.watch(cameraDarknessDetectedProvider);

    return Scaffold(
      appBar: AppBar(
        title: const Text('Selfie Theme Control'),
        leading: IconButton(
          icon: const Icon(Icons.arrow_back),
          onPressed: () => Navigator.pop(context),
        ),
      ),
      body: Column(
        children: [
          // ── Camera Preview Section ──────────────────────────────────
          Expanded(
            flex: 3,
            child: Container(
              margin: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: Colors.black,
                borderRadius: BorderRadius.circular(20),
                border: Border.all(
                  color: isDarkNow ? Colors.redAccent : AppColors.primary, 
                  width: 2
                ),
              ),
              clipBehavior: Clip.antiAlias,
              child: _buildCameraPreview(),
            ),
          ),

          // ── Controls Section ───────────────────────────────────────
          Expanded(
            flex: 2,
            child: Container(
              padding: const EdgeInsets.all(24),
              decoration: BoxDecoration(
                color: theme.cardColor,
                borderRadius: const BorderRadius.vertical(top: Radius.circular(32)),
              ),
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Row(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      Icon(
                        isDarkNow ? Icons.dark_mode : Icons.light_mode,
                        color: isDarkNow ? Colors.amber : Colors.blue,
                      ),
                      const SizedBox(width: 12),
                      Text(
                        isDarkNow ? "DARK MODE: ACTIVE" : "LIGHT MODE: ACTIVE",
                        style: theme.textTheme.titleMedium?.copyWith(
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                    ],
                  ),
                  const SizedBox(height: 16),
                  Text(
                    'Brightness: ${_lastLuminance.toStringAsFixed(1)}',
                    style: TextStyle(
                      color: isDarknessDetected ? Colors.red : Colors.green,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                  const SizedBox(height: 8),
                  const Text(
                    'Cover the SELFIE CAMERA with your finger to toggle Dark Mode.',
                    textAlign: TextAlign.center,
                    style: TextStyle(fontSize: 12),
                  ),
                  const SizedBox(height: 32),

                  // Action Buttons
                  Row(
                    children: [
                      Expanded(
                        child: ElevatedButton.icon(
                          onPressed: _isCameraInitialized ? null : _initCameras,
                          icon: const Icon(Icons.camera_front),
                          label: const Text('Start Sensing'),
                          style: ElevatedButton.styleFrom(
                            backgroundColor: AppColors.primary,
                            padding: const EdgeInsets.symmetric(vertical: 16),
                          ),
                        ),
                      ),
                      const SizedBox(width: 16),
                      Expanded(
                        child: OutlinedButton.icon(
                          onPressed: _isCameraInitialized ? _stopCamera : null,
                          icon: const Icon(Icons.stop),
                          label: const Text('Stop'),
                          style: OutlinedButton.styleFrom(
                            padding: const EdgeInsets.symmetric(vertical: 16),
                          ),
                        ),
                      ),
                    ],
                  ),
                ],
              ),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildCameraPreview() {
    if (_error != null) {
      return Center(
        child: Padding(
          padding: const EdgeInsets.all(20.0),
          child: Text(_error!, style: const TextStyle(color: Colors.white), textAlign: TextAlign.center),
        ),
      );
    }

    if (!_isCameraInitialized || _controller == null) {
      return const Center(child: CircularProgressIndicator(color: Colors.white));
    }

    return CameraPreview(_controller!);
  }
}
